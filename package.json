{
  "name": "vite-plugin-react-click-to-component",
  "type": "module",
  "version": "4.2.2",
  "private": true,
  "license": "MIT",
  "scripts": {
    "postinstall": "cd playground && bun i",
    "dev": "scripts/bundle.ts --dev",
    "build": "scripts/bundle.ts",
    "tsc": "tsl",
    "lint": "eslint --max-warnings 0",
    "format": "bun format-ci --write",
    "format-ci": "prettier --ignore-path=.gitignore --check '**/*.{ts,tsx,html,css,json,md,yml}'",
    "check": "tsl && bun run build && bun lint && bun format-ci && cd playground && tsc && bun lint && cd ../dist && bun publint"
  },
  "prettier": {
    "experimentalOperatorPosition": "start"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "vite": "^7 || ^8"
  },
  "devDependencies": {
    "@arnaud-barre/eslint-config": "^7.1.0",
    "@arnaud-barre/tsl-config": "^0.1.5",
    "@types/node": "^22.19.17",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "publint": "^0.3.18",
    "tsl": "^1.0.30",
    "typescript": "~6.0.3",
    "vite": "^8.0.8"
  }
}
